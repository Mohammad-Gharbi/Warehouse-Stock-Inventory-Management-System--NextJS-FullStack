generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid
  action     String
  entityType String
  entityId   String?  @db.Uuid
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([action])
  @@index([createdAt])
  @@index([entityType])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Category {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  userId      String    @db.Uuid
  status      Boolean   @default(true)
  description String?
  notes       String?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @db.Timestamptz(6)
  createdBy   String    @db.Uuid
  updatedBy   String?   @db.Uuid

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Department {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ImportHistory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @db.Uuid
  importType  String
  fileName    String
  fileSize    Int
  totalRows   Int
  successRows Int
  failedRows  Int
  errors      Json?
  status      String    @default("completed")
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  completedAt DateTime? @db.Timestamptz(6)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Invoice {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber         String    @unique
  orderId               String    @unique @db.Uuid
  userId                String    @db.Uuid
  clientId              String?   @db.Uuid
  status                String    @default("draft")
  subtotal              Float     @default(0)
  tax                   Float?
  shipping              Float?
  discount              Float?
  total                 Float     @default(0)
  amountPaid            Float     @default(0)
  amountDue             Float     @default(0)
  dueDate               DateTime  @db.Timestamptz(6)
  issuedAt              DateTime  @default(now()) @db.Timestamptz(6)
  sentAt                DateTime? @db.Timestamptz(6)
  paidAt                DateTime? @db.Timestamptz(6)
  cancelledAt           DateTime? @db.Timestamptz(6)
  paymentLink           String?
  stripePaymentIntentId String?
  notes                 String?
  billingAddress        Json?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime? @db.Timestamptz(6)
  createdBy             String    @db.Uuid
  updatedBy             String?   @db.Uuid
  order                 Order     @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, status, dueDate])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  type      String
  title     String
  message   String
  link      String?
  read      Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  readAt    DateTime? @db.Timestamptz(6)
  metadata  Json?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, read, createdAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Order {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber           String      @unique
  userId                String      @db.Uuid
  clientId              String?     @db.Uuid
  status                String      @default("pending")
  paymentStatus         String      @default("unpaid")
  subtotal              Float       @default(0)
  tax                   Float?
  shipping              Float?
  discount              Float?
  total                 Float       @default(0)
  shippingAddress       Json?
  billingAddress        Json?
  notes                 String?
  trackingNumber        String?
  trackingCarrier       String?
  trackingUrl           String?
  labelUrl              String?
  estimatedDelivery     DateTime?   @db.Timestamptz(6)
  shippedAt             DateTime?   @db.Timestamptz(6)
  deliveredAt           DateTime?   @db.Timestamptz(6)
  cancelledAt           DateTime?   @db.Timestamptz(6)
  stripePaymentIntentId String?
  createdAt             DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime?   @db.Timestamptz(6)
  createdBy             String      @db.Uuid
  updatedBy             String?     @db.Uuid
  invoice               Invoice?
  items                 OrderItem[]

  @@index([userId, status, createdAt])
  @@index([clientId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OrderItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @db.Uuid
  productId   String   @db.Uuid
  productName String
  sku         String?
  quantity    Int
  price       Float
  subtotal    Float
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product     Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orderId])
  @@index([productId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Permission {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource String?
  userId   String? @db.Uuid

  @@unique([userId, resource])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Product {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String      @db.Uuid
  createdAt        DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?   @db.Timestamptz(6)
  name             String
  price            Float
  quantity         BigInt
  reservedQuantity BigInt      @default(0)
  sku              String      @unique
  status           String
  supplierId       String      @db.Uuid
  userId           String      @db.Uuid
  createdBy        String      @db.Uuid
  updatedBy        String?     @db.Uuid
  qrCodeUrl        String?
  qrCodeFileId     String?
  imageUrl         String?
  imageFileId      String?
  expirationDate   DateTime?   @db.Timestamptz(6)
  deletedAt        DateTime?   @db.Timestamptz(6)
  deletedBy        String?     @db.Uuid
  orderItems       OrderItem[]

  @@index([deletedAt])
  @@index([userId, deletedAt, createdAt])
  @@index([categoryId])
  @@index([supplierId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ProductReview {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String    @db.Uuid
  userId      String    @db.Uuid
  orderId     String?   @db.Uuid
  orderItemId String?   @db.Uuid
  productName String
  productSku  String?
  rating      Int
  comment     String
  status      String    @default("pending")
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @db.Timestamptz(6)

  @@index([createdAt])
  @@index([orderId])
  @@index([orderId, productId, userId])
  @@index([productId])
  @@index([rating])
  @@index([status])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Session {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String? @unique
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model StockAlert {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model StockAllocation {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId        String    @db.Uuid
  warehouseId      String    @db.Uuid
  quantity         BigInt    @default(0)
  reservedQuantity BigInt    @default(0)
  userId           String    @db.Uuid
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime? @db.Timestamptz(6)

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model StockTransfer {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String    @db.Uuid
  fromWarehouseId String    @db.Uuid
  toWarehouseId   String    @db.Uuid
  quantity        BigInt
  status          String    @default("pending")
  notes           String?
  userId          String    @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  completedAt     DateTime? @db.Timestamptz(6)

  @@index([fromWarehouseId])
  @@index([productId])
  @@index([status])
  @@index([toWarehouseId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Supplier {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  userId      String    @db.Uuid
  status      Boolean   @default(true)
  description String?
  notes       String?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @db.Timestamptz(6)
  createdBy   String    @db.Uuid
  updatedBy   String?   @db.Uuid

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model SupportTicket {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject            String
  description        String
  status             String               @default("open")
  priority           String               @default("medium")
  userId             String               @db.Uuid
  assignedToId       String?              @db.Uuid
  productId          String?              @db.Uuid
  orderId            String?              @db.Uuid
  supplierId         String?              @db.Uuid
  notes              String?
  createdAt          DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime?            @db.Timestamptz(6)
  replies            SupportTicketReply[]

  @@index([assignedToId])
  @@index([createdAt])
  @@index([status])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model SupportTicketReply {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId      String        @db.Uuid
  userId        String        @db.Uuid
  body          String
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  supportTicket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt])
  @@index([ticketId])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model SystemConfig {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String    @unique
  value       String
  type        String    @default("string")
  label       String
  description String?
  category    String    @default("general")
  isPublic    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @db.Timestamptz(6)
  updatedBy   String?   @db.Uuid

  @@index([category])
  @@index([isPublic])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime       @db.Timestamptz(6)
  email            String         @unique
  name             String         @default("")
  updatedAt        DateTime?      @db.Timestamptz(6)
  username         String?        @unique
  image            String?
  role             user_role      @default(user)
  emailPreferences Json?
  notifications    Notification[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model UserAction {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model VerificationToken {
  id    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token String? @unique
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Warehouse {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  address   String?
  type      String?
  status    Boolean   @default(true)
  userId    String    @db.Uuid
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @db.Timestamptz(6)
  createdBy String    @db.Uuid
  updatedBy String?   @db.Uuid

  @@index([userId])
}

enum user_role {
  user
  admin
  supplier
  client
  retailer
}
